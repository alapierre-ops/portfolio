# Local dev: copy to .env — server loads .env automatically; `npm run dev` starts API + Vite
GROQ_API_KEY=
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PORT=8787

# Production API host (Render, etc.) — set on Netlify at build time (no trailing slash)
# Leave empty for local dev (Vite proxies /api to localhost:8787)
VITE_CHAT_API_BASE=

# Analytics (cookieless, no consent banner). Configure ONE provider — or none.
# Nothing loads and nothing is tracked unless one of these is set.
#
# Plausible (hosted plausible.io, or self-hosted):
VITE_PLAUSIBLE_DOMAIN=
# VITE_PLAUSIBLE_SRC=https://plausible.io/js/script.js   # only if self-hosted
#
# — or — Umami (cloud.umami.is or self-hosted):
# VITE_UMAMI_WEBSITE_ID=
# VITE_UMAMI_SRC=https://cloud.umami.is/script.js
